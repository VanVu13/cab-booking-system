{
    "openapi": "3.0.0",
    "info": {
        "title": "CAB BOOKING SYSTEM API",
        "description": "Unified API Documentation for all Microservices via API Gateway",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:3000",
            "description": "API Gateway"
        }
    ],
    "paths": {
        "/auth/register": {
            "post": {
                "tags": [
                    "Auth Service"
                ],
                "summary": "User Registration",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "user@example.com"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": [
                                            "PASSENGER",
                                            "DRIVER"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "userId": {
                                            "type": "string"
                                        },
                                        "accessToken": {
                                            "type": "string"
                                        },
                                        "refreshToken": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth Service"
                ],
                "summary": "User Login",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "user@example.com"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "userId": {
                                            "type": "string"
                                        },
                                        "role": {
                                            "type": "string"
                                        },
                                        "accessToken": {
                                            "type": "string"
                                        },
                                        "refreshToken": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "tags": [
                    "Auth Service"
                ],
                "summary": "Refresh Access Token",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "refreshToken": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token refreshed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "accessToken": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/users/profile": {
            "get": {
                "tags": [
                    "User Service"
                ],
                "summary": "Get User Profile",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Profile data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "userId": {
                                            "type": "string"
                                        },
                                        "name": {
                                            "type": "string"
                                        },
                                        "email": {
                                            "type": "string"
                                        },
                                        "role": {
                                            "type": "string"
                                        },
                                        "phone": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "patch": {
                "tags": [
                    "User Service"
                ],
                "summary": "Update User Profile",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "licenseNumber": {
                                        "type": "string",
                                        "description": "Only for DRIVER"
                                    },
                                    "vehicleDetails": {
                                        "type": "object",
                                        "description": "Only for DRIVER"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/pricing/estimate": {
            "get": {
                "tags": [
                    "Pricing Service"
                ],
                "summary": "Get price estimate (Query)",
                "parameters": [
                    {
                        "name": "pickupLat",
                        "in": "query",
                        "schema": {
                            "type": "number",
                            "example": 10.7
                        }
                    },
                    {
                        "name": "pickupLng",
                        "in": "query",
                        "schema": {
                            "type": "number",
                            "example": 106.6
                        }
                    },
                    {
                        "name": "dropLat",
                        "in": "query",
                        "schema": {
                            "type": "number",
                            "example": 10.8
                        }
                    },
                    {
                        "name": "dropLng",
                        "in": "query",
                        "schema": {
                            "type": "number",
                            "example": 106.7
                        }
                    },
                    {
                        "name": "vehicleType",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "example": "SEDAN"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Estimate details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "estimatedPrice": {
                                            "type": "number",
                                            "example": 85000
                                        },
                                        "currency": {
                                            "type": "string",
                                            "example": "VND"
                                        },
                                        "surgeMultiplier": {
                                            "type": "number",
                                            "example": 1.2
                                        },
                                        "breakdown": {
                                            "type": "object",
                                            "properties": {
                                                "base": {
                                                    "type": "number",
                                                    "example": 15000
                                                },
                                                "distance": {
                                                    "type": "number",
                                                    "example": 50000
                                                },
                                                "time": {
                                                    "type": "number",
                                                    "example": 20000
                                                }
                                            }
                                        },
                                        "details": {
                                            "type": "object",
                                            "properties": {
                                                "distanceKm": {
                                                    "type": "number",
                                                    "example": 5.2
                                                },
                                                "estimatedMinutes": {
                                                    "type": "number",
                                                    "example": 10
                                                },
                                                "vehicleType": {
                                                    "type": "string",
                                                    "example": "SEDAN"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Pricing Service"
                ],
                "summary": "Get price estimate (JSON)",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "pickup": {
                                        "type": "object",
                                        "properties": {
                                            "lat": {
                                                "type": "number"
                                            },
                                            "lng": {
                                                "type": "number"
                                            }
                                        }
                                    },
                                    "drop": {
                                        "type": "object",
                                        "properties": {
                                            "lat": {
                                                "type": "number"
                                            },
                                            "lng": {
                                                "type": "number"
                                            }
                                        }
                                    },
                                    "vehicleType": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Estimate details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "estimatedPrice": {
                                            "type": "number",
                                            "example": 85000
                                        },
                                        "currency": {
                                            "type": "string",
                                            "example": "VND"
                                        },
                                        "surgeMultiplier": {
                                            "type": "number",
                                            "example": 1.2
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/reviews": {
            "post": {
                "tags": [
                    "Review Service"
                ],
                "summary": "Submit a review",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "rideId",
                                    "rating"
                                ],
                                "properties": {
                                    "rideId": {
                                        "type": "string",
                                        "example": "r123"
                                    },
                                    "rating": {
                                        "type": "integer",
                                        "minimum": 1,
                                        "maximum": 5,
                                        "example": 5
                                    },
                                    "comment": {
                                        "type": "string",
                                        "example": "Tài xế thân thiện"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Review submitted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "review_submitted"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/reviews/driver/{driverId}": {
            "get": {
                "tags": [
                    "Review Service"
                ],
                "summary": "Get reviews for a driver",
                "parameters": [
                    {
                        "name": "driverId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Driver reviews",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "averageRating": {
                                            "type": "number",
                                            "example": 4.8
                                        },
                                        "reviews": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/drivers/location": {
            "post": {
                "tags": [
                    "Driver Service"
                ],
                "summary": "Update Driver Location",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "lat": {
                                        "type": "number"
                                    },
                                    "lng": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Location updated"
                    }
                }
            }
        },
        "/drivers/nearby": {
            "get": {
                "tags": [
                    "Driver Service"
                ],
                "summary": "Get nearby drivers",
                "parameters": [
                    {
                        "name": "lat",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "lng",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "radius",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of nearby drivers"
                    }
                }
            }
        },
        "/bookings": {
            "get": {
                "tags": [
                    "Booking Service"
                ],
                "summary": "Get bookings by user",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of bookings"
                    }
                }
            },
            "post": {
                "tags": [
                    "Booking Service"
                ],
                "summary": "Create a new booking",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "pickup",
                                    "drop"
                                ],
                                "properties": {
                                    "pickup": {
                                        "type": "object",
                                        "required": [
                                            "lat",
                                            "lng"
                                        ],
                                        "properties": {
                                            "lat": {
                                                "type": "number",
                                                "example": 10.7
                                            },
                                            "lng": {
                                                "type": "number",
                                                "example": 106.6
                                            }
                                        }
                                    },
                                    "drop": {
                                        "type": "object",
                                        "required": [
                                            "lat",
                                            "lng"
                                        ],
                                        "properties": {
                                            "lat": {
                                                "type": "number",
                                                "example": 10.8
                                            },
                                            "lng": {
                                                "type": "number",
                                                "example": 106.7
                                            }
                                        }
                                    },
                                    "vehicleType": {
                                        "type": "string",
                                        "enum": [
                                            "SEDAN",
                                            "SUV",
                                            "BIKE"
                                        ],
                                        "example": "SEDAN"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Booking created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "bookingId": {
                                            "type": "string"
                                        },
                                        "status": {
                                            "type": "string",
                                            "enum": [
                                                "CREATED",
                                                "SEARCHING_DRIVER",
                                                "DRIVER_ASSIGNED",
                                                "IN_PROGRESS",
                                                "COMPLETED",
                                                "CANCELLED",
                                                "MATCH_FAILED"
                                            ]
                                        },
                                        "estimatedPrice": {
                                            "type": "number"
                                        },
                                        "currency": {
                                            "type": "string"
                                        },
                                        "pickupEtaSeconds": {
                                            "type": "number"
                                        },
                                        "tripEtaSeconds": {
                                            "type": "number"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/bookings/{id}": {
            "get": {
                "tags": [
                    "Booking Service"
                ],
                "summary": "Get booking progress",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Booking details"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Booking Service"
                ],
                "summary": "Cancel booking",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Booking cancelled"
                    }
                }
            }
        },
        "/rides/{id}": {
            "get": {
                "tags": [
                    "Ride Service"
                ],
                "summary": "Get ride details",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ride details"
                    }
                }
            }
        },
        "/rides/{id}/start": {
            "post": {
                "tags": [
                    "Ride Service"
                ],
                "summary": "Start ride",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ride started"
                    }
                }
            }
        },
        "/rides/{id}/complete": {
            "post": {
                "tags": [
                    "Ride Service"
                ],
                "summary": "Complete ride",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "distanceMeters": {
                                        "type": "number"
                                    },
                                    "durationSeconds": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Ride completed"
                    }
                }
            }
        },
        "/notifications": {
            "get": {
                "tags": [
                    "Notification Service"
                ],
                "summary": "Get all notifications",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of notifications"
                    }
                }
            }
        },
        "/notifications/{id}": {
            "get": {
                "tags": [
                    "Notification Service"
                ],
                "summary": "Get notification by ID",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notification details"
                    }
                }
            }
        },
        "/notifications/{id}/read": {
            "patch": {
                "tags": [
                    "Notification Service"
                ],
                "summary": "Mark notification as read",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notification marked as read"
                    }
                }
            }
        },
        "/payments/charge": {
            "post": {
                "tags": [
                    "Payment Service"
                ],
                "summary": "Charge payment",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "rideId": {
                                        "type": "string"
                                    },
                                    "amount": {
                                        "type": "number"
                                    },
                                    "paymentMethod": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Payment processing"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}